# LLM Provider Configuration
# Supported: openai (OpenAI compatible endpoints like OpenAI, Qwen, GLM, DeepSeek, Kimi, Doubao, MiniMax),
#            anthropic (Anthropic Claude API)
LLM_PROVIDER=openai

# OpenAI / Compatible LLM Configuration
# For Chinese domestic models like Qwen, GLM, DeepSeek, Kimi, Doubao, set BASE_URL to your endpoint
BASE_URL=https://api.openai.com/v1
API_KEY=your_api_key_here

# Anthropic Configuration (only needed when LLM_PROVIDER=anthropic)
# For direct Anthropic API:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# API_KEY=your_anthropic_api_key
#
# For proxy/ByteDance Volcano Ark that compatible with Anthropic protocol:
# ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# API_KEY=your_ark_api_key
# LLM_MODEL=ark-code-latest

# Model configuration
# OpenAI recommended: gpt-4o, qwen-turbo, qwen-plus, glm-4, deepseek-v3, deepseek-chat, doubao-seed-2.0-pro, minimax-m2.7, kimi-k2
# Anthropic recommended: claude-3-5-sonnet-20241022, claude-3-opus-20240229
LLM_MODEL=gpt-4o

# ArXiv categories (comma-separated)
# 默认追踪芯片架构与EDA相关分类
ARXIV_CATEGORIES=cs.AR,cs.DC,cs.ET,cs.AI

# Max results per sync
# scheduler 每次同步默认抓取最新多少篇论文
MAX_RESULTS=100

# Generation parameters
# Temperature: 0.0-1.0, lower = more deterministic/focused, higher = more creative
# 评分任务用较低温度保证一致性，深度推文生成可以用 0.3-0.5
TEMPERATURE=0.3

# Timeout in seconds for API calls
# `TIMEOUT_SCORING`: 评分任务超时（秒），默认 120
# `TIMEOUT_SYNTHESIS`: 深度推文生成超时（秒），默认 300
# 如果生成经常卡住，可以调大超时
TIMEOUT_SCORING=120
TIMEOUT_SYNTHESIS=300
TIMEOUT_DOWNLOAD=120

# Optional embedding config for paragraph/caption similarity ranking.
# If your chat endpoint is a coding-only endpoint, use a standard OpenAI-compatible base URL here.
# For Volcano Ark, EMBEDDING_BASE_URL is usually https://ark.cn-beijing.volces.com/api/v3
# and EMBEDDING_MODEL should be your actual embedding endpoint ID or a model you can access.
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
# EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_SIZE=16
EMBEDDING_SIMILARITY_THRESHOLD=0.18
EMBEDDING_CACHE_PATH=./data/embedding_cache.json

# Max tokens for output
# MAX_TOKENS_SCORING: AI评分任务，只输出JSON，不需要太长
# MAX_TOKENS_SYNTHESIS: 深度推文生成，支持长输出，DeepSeek-V3.2/GLM-5.1等可支持到 128k+
# 如果生成卡住超时，可以减小到 4096 或 8192
MAX_TOKENS_SCORING=2000
MAX_TOKENS_SYNTHESIS=16384

# Database path
DB_PATH=./data/papers.db

# PDF storage path
PDF_DIR=./pdfs
